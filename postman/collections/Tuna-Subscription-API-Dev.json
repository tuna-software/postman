{
	"info": {
		"_postman_id": "subscription-dev-localhost-001",
		"name": "Tuna Subscription API - Development",
		"description": "Development collection for testing Tuna Subscription API on localhost:5267.\n\n## Subscription Management\n\nThis collection provides comprehensive testing for all subscription-related operations:\n\n- **Subscription Lifecycle**: Initialize, update, pause, resume, and cancel subscriptions\n- **Invoice Management**: List and retrieve invoice details with pagination and sorting\n- **Subscriber Management**: Get and update subscriber information\n\n## Authentication\n\nAll requests use:\n- x-tuna-apptoken header for token authentication (collection-level)\n- x-tuna-account header for account identification (request-level)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "apikey",
		"apikey": [
			{
				"key": "value",
				"value": "{{x-tuna-apptoken}}",
				"type": "string"
			},
			{
				"key": "key",
				"value": "x-tuna-apptoken",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Subscription",
			"description": "Complete subscription management workflow",
			"item": [
				{
					"name": "1. Init Subscription",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsondata = JSON.parse(pm.response.text());",
									"if (jsondata.subscriptionKey != null) {",
									"    pm.collectionVariables.set(\"subscriptionKey\", jsondata.subscriptionKey);",
									"}",
									"if (jsondata.paymentKey != null) {",
									"    pm.collectionVariables.set(\"paymentKey\", jsondata.paymentKey);",
									"}",
									"if (jsondata.subscriberId != null) {",
									"    pm.collectionVariables.set(\"subscriberId\", jsondata.subscriberId);",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"pm.collectionVariables.set(\"customerName\", \"{{$randomFirstName}} {{$randomLastName}}\");",
									"pm.collectionVariables.set(\"partnerUniqueId\", \"{{$randomUUID}}\");"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "x-tuna-account", "value": "{{x-tuna-account}}", "type": "string"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"partnerUniqueId\": \"{{partnerUniqueId}}\",\n    \"customer\": {\n        \"name\": \"{{customerName}}\",\n        \"email\": \"{{$randomEmail}}\",\n        \"document\": \"08714597799\",\n        \"documentType\": \"CPF\",\n        \"phone\": \"{{$randomPhoneNumber}}\"\n    },\n    \"paymentItems\": {\n        \"items\": [{\n            \"productDescription\": \"{{$randomProductName}}\",\n            \"amount\": 99.90,\n            \"itemQuantity\": 1\n        }]\n    },\n    \"paymentData\": {\n        \"amount\": 99.90,\n        \"paymentMethods\": [{\n            \"paymentMethodType\": \"1\",\n            \"amount\": 99.90,\n            \"installments\": 1,\n            \"cardInfo\": {\n                \"cardNumber\": \"4111111111111111\",\n                \"cardHolderName\": \"{{customerName}}\",\n                \"expirationMonth\": 12,\n                \"expirationYear\": 2028,\n                \"cvv\": \"123\",\n                \"saveCard\": false,\n                \"billingInfo\": {\n                    \"name\": \"{{customerName}}\",\n                    \"address\": {\n                        \"street\": \"{{$randomStreetAddress}}\",\n                        \"number\": \"{{$randomInt}}\",\n                        \"city\": \"{{$randomCity}}\",\n                        \"state\": \"SP\",\n                        \"country\": \"BR\",\n                        \"postalCode\": \"01310-100\"\n                    }\n                }\n            }\n        }]\n    },\n    \"subscription\": {\n        \"description\": \"{{$randomProductName}} Subscription\",\n        \"interval\": {\n            \"intervalType\": \"month\",\n            \"intervalQuantity\": 1\n        },\n        \"subscriber\": {\n            \"externalId\": \"ext-{{$randomInt}}\",\n            \"name\": \"{{customerName}}\",\n            \"email\": \"{{$randomEmail}}\"\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/subscriptions",
							"host": ["{{baseUrl}}"],
							"path": ["api", "subscriptions"]
						}
					},
					"response": []
				},
				{
					"name": "2. Get Subscription Details",
					"request": {
						"method": "GET",
						"header": [{"key": "x-tuna-account", "value": "{{x-tuna-account}}", "type": "string"}],
						"url": {
							"raw": "{{baseUrl}}/api/subscription/{{subscriptionKey}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "subscription", "{{subscriptionKey}}"]
						}
					},
					"response": []
				},
				{
					"name": "3. Update Subscription Items",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "x-tuna-account", "value": "{{x-tuna-account}}", "type": "string"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"items\": [{\n        \"description\": \"{{$randomProductName}} (Updated)\",\n        \"amount\": 129.90,\n        \"quantity\": 1\n    }]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/subscription/{{subscriptionKey}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "subscription", "{{subscriptionKey}}"]
						}
					},
					"response": []
				},
				{
					"name": "4. Pause Subscription",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "x-tuna-account", "value": "{{x-tuna-account}}", "type": "string"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"reason\": \"Customer requested temporary suspension\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/subscription/{{subscriptionKey}}/pause",
							"host": ["{{baseUrl}}"],
							"path": ["api", "subscription", "{{subscriptionKey}}", "pause"]
						}
					},
					"response": []
				},
				{
					"name": "5. Resume Subscription",
					"request": {
						"method": "POST",
						"header": [{"key": "x-tuna-account", "value": "{{x-tuna-account}}", "type": "string"}],
						"url": {
							"raw": "{{baseUrl}}/api/subscription/{{subscriptionKey}}/resume",
							"host": ["{{baseUrl}}"],
							"path": ["api", "subscription", "{{subscriptionKey}}", "resume"]
						}
					},
					"response": []
				},
				{
					"name": "6. Cancel Subscription",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "x-tuna-account", "value": "{{x-tuna-account}}", "type": "string"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"reason\": \"Service no longer needed\",\n    \"cancelImmediately\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/subscription/{{subscriptionKey}}/cancel",
							"host": ["{{baseUrl}}"],
							"path": ["api", "subscription", "{{subscriptionKey}}", "cancel"]
						}
					},
					"response": []
				},
				{
					"name": "7. List Invoices",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsondata = JSON.parse(pm.response.text());",
									"if (jsondata.invoices && jsondata.invoices.length > 0) {",
									"    pm.collectionVariables.set(\"invoiceKey\", jsondata.invoices[0].invoiceKey);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [{"key": "x-tuna-account", "value": "{{x-tuna-account}}", "type": "string"}],
						"url": {
							"raw": "{{baseUrl}}/api/subscription/{{subscriptionKey}}/invoices?page=1&pageSize=20&sortBy=cycleNumber&sortDescending=true",
							"host": ["{{baseUrl}}"],
							"path": ["api", "subscription", "{{subscriptionKey}}", "invoices"],
							"query": [
								{"key": "page", "value": "1"},
								{"key": "pageSize", "value": "20"},
								{"key": "sortBy", "value": "cycleNumber"},
								{"key": "sortDescending", "value": "true"}
							]
						}
					},
					"response": []
				},
				{
					"name": "8. Get Invoice Details",
					"request": {
						"method": "GET",
						"header": [{"key": "x-tuna-account", "value": "{{x-tuna-account}}", "type": "string"}],
						"url": {
							"raw": "{{baseUrl}}/api/subscription/invoice/{{invoiceKey}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "subscription", "invoice", "{{invoiceKey}}"]
						}
					},
					"response": []
				},
				{
					"name": "9. Get Subscriber by External ID",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsondata = JSON.parse(pm.response.text());",
									"if (jsondata.subscriberId != null) {",
									"    pm.collectionVariables.set(\"subscriberId\", jsondata.subscriberId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [{"key": "x-tuna-account", "value": "{{x-tuna-account}}", "type": "string"}],
						"url": {
							"raw": "{{baseUrl}}/api/subscription/subscriber/1/ext-12345",
							"host": ["{{baseUrl}}"],
							"path": ["api", "subscription", "subscriber", "1", "ext-12345"]
						}
					},
					"response": []
				},
				{
					"name": "10. Update Subscriber",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "x-tuna-account", "value": "{{x-tuna-account}}", "type": "string"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"{{$randomFirstName}} {{$randomLastName}}\",\n    \"email\": \"{{$randomEmail}}\",\n    \"phone\": \"{{$randomPhoneNumber}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/subscription/subscriber/1/{{subscriberId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "subscription", "subscriber", "1", "{{subscriberId}}"]
						}
					},
					"response": []
				},
				{
					"name": "11. List Active Subscriptions",
					"request": {
						"method": "GET",
						"header": [{"key": "x-tuna-account", "value": "{{x-tuna-account}}", "type": "string"}],
						"url": {
							"raw": "{{baseUrl}}/api/subscription/active?page=1&pageSize=20",
							"host": ["{{baseUrl}}"],
							"path": ["api", "subscription", "active"],
							"query": [
								{"key": "page", "value": "1"},
								{"key": "pageSize", "value": "20"}
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{"key": "baseUrl", "value": "http://localhost:5267", "type": "string"},
		{"key": "x-tuna-apptoken", "value": "your-app-token-here", "type": "string"},
		{"key": "x-tuna-account", "value": "your-account-id-here", "type": "string"},
		{"key": "subscriptionKey", "value": "", "type": "string"},
		{"key": "invoiceKey", "value": "", "type": "string"},
		{"key": "subscriberId", "value": "", "type": "string"},
		{"key": "paymentKey", "value": "", "type": "string"},
		{"key": "customerName", "value": "", "type": "string"},
		{"key": "partnerUniqueId", "value": "", "type": "string"}
	]
}
